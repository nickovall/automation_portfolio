      "id": "4f2ba4fb-5cfd-4dbf-8e34-a92355cc9baf",
      "name": "N08_Set_FQ_LookupRequest"
    },
    {
      "parameters": {
        "jsCode": "// Берём request из N08 и сразу делаем \"чистую\" копию\nconst reqRaw = $node[\"N08_Set_FQ_LookupRequest\"].json;\nconst req = { ...reqRaw };\ndelete req.__lookup_marker;\ndelete req.fq_lookup_ts;\n\nconst row = $json;\n\n// детектор нашли / не нашли\nconst isEmpty = !row || Object.keys(row).length === 0;\n\n// echo-item может прийти либо как request с marker,\n// либо как пустой объект {} (как у тебя на скрине)\nconst isEcho = row.__lookup_marker === \"request\" || !!row.fq_lookup_ts;\n\n// если нашли реальную строку — у неё должен быть queue_id\nconst hasQueueId = !!row.queue_id;\n\nconst found = !(isEmpty || isEcho || !hasQueueId);\n\n// дефолт для новой записи\nconst now = new Date().toISOString();\nconst base = {\n  queue_id: req.queue_id,\n  order_uid: req.order_uid,\n  queued_at: now,\n  pick_status: \"queued\",\n  pack_status: \"not_started\",\n  shipment_status: \"not_started\",\n  assigned_to: \"\",\n  cutoff_date: req.promised_ship_date || \"\",\n  exception_flag: \"no\",\n  exception_reason: \"\",\n  last_updated_at: now,\n};\n\nlet merged;\n\nif (found) {\n  // ВАЖНО: сохраняем то, что уже было в очереди (queued_at, pick_status, pack_status, shipment_status)\n  merged = {\n    ...base,\n    ...row,\n    order_uid: req.order_uid,\n    cutoff_date: row.cutoff_date || base.cutoff_date,\n    last_updated_at: now,\n  };\n} else {\n  merged = base;\n}\n\n// чистим сервисные поля, если вдруг попали из row\ndelete merged.__lookup_marker;\ndelete merged.fq_lookup_ts;\n\n// готовый payload под UTIL_Upsert_Sheet_Record\nreturn [{\n  json: {\n    ...req,\n    ...merged,\n    target_sheet: \"13_Fulfillment_Queue\",\n    fq_row_found: found,\n  }\n}];"
      },
