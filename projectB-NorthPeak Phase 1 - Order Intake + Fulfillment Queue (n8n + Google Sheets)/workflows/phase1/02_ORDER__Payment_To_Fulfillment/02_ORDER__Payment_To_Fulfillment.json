    {
      "parameters": {
        "jsCode": "const o = $json;\n\n// нормализация\nconst payment = String(o.payment_status || \"\").trim().toLowerCase();\nconst hold = String(o.hold_review || \"no\").trim().toLowerCase();\nconst current = String(o.current_status || \"\").trim().toLowerCase();\nconst fulfill = String(o.fulfillment_status || \"\").trim().toLowerCase();\n\nconst order_uid = o.order_uid;\nconst queue_id = \"fq_\" + order_uid;\n\n// 1) когда мы ВООБЩЕ имеем право трогать fulfillment очередь\nconst should_ensure_queue =\n  payment === \"paid\" &&\n  hold === \"no\" &&\n  ![\"cancelled\", \"refunded\"].includes(current);\n\n// 2) когда можно обновлять сам заказ до queued (только ранняя стадия)\nconst should_update_order_to_queued =\n  should_ensure_queue &&\n  [\"new\", \"paid\", \"\"].includes(current) &&\n  [\"not_started\", \"\"].includes(fulfill);\n\n// причины (для логов/алертов)\nlet skip_reason = \"\";\nif (!should_ensure_queue) {\n  if (payment !== \"paid\") skip_reason = \"skip_payment_not_paid\";\n  else if (hold !== \"no\") skip_reason = \"skip_hold_review\";\n  else if ([\"cancelled\",\"refunded\"].includes(current)) skip_reason = \"skip_order_closed_\" + current;\n  else skip_reason = \"skip_unknown\";\n}\n\nreturn [{\n  json: {\n    ...o,\n    order_uid,\n    queue_id,\n    should_ensure_queue,\n    should_update_order_to_queued,\n    skip_reason,\n  }\n}];"
      },
